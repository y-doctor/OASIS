#!/bin/bash
#SBATCH --job-name=revfsa_dryrun
#SBATCH --partition=condo
#SBATCH --qos=condo
#SBATCH --nodes=1
#SBATCH --tasks-per-node=8
#SBATCH --time=00:30:00
#SBATCH --mem=32G
#SBATCH --account=csd852
#SBATCH -o /tscc/projects/ps-malilab/ydoctor/Ligandome_Screens/revision_scripts/dryrun_Day6_PL.out
#SBATCH --mail-type=FAIL
#SBATCH --mail-user=ydoctor@ucsd.edu
#SBATCH --no-requeue

eval "$(conda shell.bash hook)"
conda activate perturb_seq_env

python /tscc/projects/ps-malilab/ydoctor/Ligandome_Screens/revision_scripts/revision_feature_set_analysis.py \
    --h5ad /tscc/projects/ps-malilab/ydoctor/Ligandome_Screens/Perturb_Seq_Analysis/anndata_objects/Day6_Ligandome_Aggregate_Post_Energy_Test.h5ad \
    --day Day6 \
    --panel PL \
    --output-dir /tscc/projects/ps-malilab/ydoctor/Ligandome_Screens/revision_figures/feature_set_analysis_dryrun \
    --n-permutations 100
