#!/bin/bash
#SBATCH --job-name=ntcz_dotplot
#SBATCH --partition=condo
#SBATCH --qos=condo
#SBATCH --nodes=1
#SBATCH --tasks-per-node=4
#SBATCH --time=00:30:00
#SBATCH --mem=64G
#SBATCH --account=csd852
#SBATCH -o /tscc/projects/ps-malilab/ydoctor/Ligandome_Screens/revision_scripts/run_ntcz_dotplot.out
#SBATCH --no-requeue

eval "$(conda shell.bash hook)"
conda activate perturb_seq_env

SCRIPT=/tscc/projects/ps-malilab/ydoctor/Ligandome_Screens/revision_scripts/make_ntcz_dotplot.py
OUT=/tscc/projects/ps-malilab/ydoctor/Ligandome_Screens/revision_figures/feature_set_analysis
H5_DIR=/tscc/projects/ps-malilab/ydoctor/Ligandome_Screens/Perturb_Seq_Analysis/anndata_objects

python "$SCRIPT" --h5ad "$H5_DIR/Day6_Ligandome_Aggregate_Post_Energy_Test.h5ad" --day Day6 --output-dir "$OUT"
python "$SCRIPT" --h5ad "$H5_DIR/Day4_Ligandome_Aggregate_Post_Energy_Test.h5ad" --day Day4 --output-dir "$OUT"
echo DONE
